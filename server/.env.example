# Copy this file to .env and fill in real values

PORT=5000

# MongoDB Atlas connection string (create a NEW user for this project)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/legion_hotel?retryWrites=true&w=majority

# Amadeus API (https://developers.amadeus.com/)
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Allowed origin for CORS (your deployed frontend)
CLIENT_ORIGIN=http://localhost:5173
